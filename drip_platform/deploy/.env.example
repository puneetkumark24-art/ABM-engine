# Copy to deploy/.env and fill in. docker compose reads it automatically.

# --- database passwords ---
POSTGRES_PASSWORD=change-postgres-superuser-pw
APP_DB_PASSWORD=change-app_rw-runtime-pw

# --- security ---
# 32+ random bytes. In production use a rotated key from your secrets manager.
JWT_SECRET=change-me-to-a-long-random-secret
# webhook HMAC key from your ESP (Mandrill). Leave blank until wired.
MANDRILL_WEBHOOK_KEY=

# --- sending (kept OFF until you enable it deliberately) ---
ENABLE_SES_TRANSPORT=false
AWS_SES_REGION=me-south-1
SES_FROM=noreply@decimaltechnologies.com

# --- behavior ---
# AUTH_ENFORCED=true rejects unauthenticated calls on protected routes.
AUTH_ENFORCED=true
SCHEDULER_TICK=15
RESPECT_SEND_WINDOW=true
SCHEDULER_TIMEZONE=Asia/Riyadh
WEB_CONCURRENCY=2
WORKER_BATCH=20
